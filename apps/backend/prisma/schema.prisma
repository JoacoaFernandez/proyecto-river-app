generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password_hash String
  display_name  String
  avatar_url    String?
  role          String     @default("user")
  created_at    DateTime   @default(now())
  Comment       Comment[]
  news          News[]
  NewsLike      NewsLike[]
}

model Match {
  id             String      @id @default(uuid())
  homeTeam       String
  awayTeam       String
  homeScore      Int?
  awayScore      Int?
  status         String
  minute         Int?
  competition    String?
  date           DateTime
  type           String      @unique
  updatedAt      DateTime
  manualOverride Boolean     @default(false)
  stadium        String?
  formations     Formation[]
}

model Player {
  id          String   @id @default(uuid())
  name        String
  position    String
  number      Int?
  age         Int?
  photo       String?
  nationality String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Formation {
  id       String  @id @default(uuid())
  matchId  String
  scheme   String
  isLineup Boolean @default(true)
  match    Match   @relation(fields: [matchId], references: [id])
}

model News {
  id          String     @id @default(uuid())
  title       String
  body        String
  category    String
  slug        String     @unique
  url         String?
  status      String     @default("draft")
  publishedAt DateTime?
  authorId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  imageUrl    String?
  Comment     Comment[]
  author      User       @relation(fields: [authorId], references: [id])
  NewsLike    NewsLike[]
}

model Comment {
  id        String   @id
  newsId    String
  userId    String
  body      String
  createdAt DateTime @default(now())
  News      News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NewsLike {
  id     String @id
  newsId String
  userId String
  News   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  User   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([newsId, userId])
}
