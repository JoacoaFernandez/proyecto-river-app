generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------
// TABLA DE USUARIOS (Hinchas, Editores y Admin)
// --------------------------------------------------
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  display_name  String
  avatar_url    String?
  role          String   @default("user") 
  created_at    DateTime @default(now())
  news          News[]   // Relación: Un usuario puede escribir varias noticias
}

// --------------------------------------------------
// TABLA DE PARTIDOS
// --------------------------------------------------
model Match {
  id          String   @id @default(uuid())
  matchDate   DateTime
  homeTeam    String
  awayTeam    String
  homeScore   Int      @default(0)
  awayScore   Int      @default(0)
  status      String   @default("scheduled")
  stadium     String?
  referee     String?
  minute      Int?
  createdAt   DateTime @default(now())
  formations  Formation[] // Relación: Un partido tiene formaciones
}

// --------------------------------------------------
// TABLA DEL PLANTEL / JUGADORES
// --------------------------------------------------
model Player {
  id          String   @id @default(uuid())
  name        String
  position    String   // 'Goalkeeper', 'Defender', 'Midfielder', 'Attacker'
  number      Int?     // Dorsal del jugador
  age         Int?     // Edad
  photo       String?  // URL de la foto oficial de la API
  nationality String?  // Nacionalidad
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --------------------------------------------------
// TABLA DE FORMACIONES TÁCTICAS
// --------------------------------------------------
model Formation {
  id        String  @id @default(uuid())
  matchId   String
  match     Match   @relation(fields: [matchId], references: [id])
  scheme    String  // ej: 4-3-3
  isLineup  Boolean @default(true)
}

// --------------------------------------------------
// TABLA DE NOTICIAS
// --------------------------------------------------
model News {
  id          String   @id @default(uuid())
  title       String
  body        String
  category    String
  slug        String   @unique
  url         String?  // 👈 AGREGAR ESTA LÍNEA (con el ? para que sea opcional y no rompa lo anterior)
  status      String   @default("draft")
  publishedAt DateTime?
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}