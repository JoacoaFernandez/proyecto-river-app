generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password_hash   String
  display_name    String
  avatar_url      String?
  role            String            @default("user")
  created_at      DateTime          @default(now())
  points          Int               @default(0)
  city            String?
  country         String?
  fanSince        Int?
  notifGoals      Boolean           @default(true)
  notifMatch      Boolean           @default(true)
  notifNews       Boolean           @default(false)
  quietFrom       Int?
  quietTo         Int?
  comments        Comment[]
  liveChatMsgs    LiveChatMessage[]
  news            News[]
  likes           NewsLike[]
  predictions     Prediction[]
  commentLikes    CommentLike[]
}

model Player {
  id               String    @id @default(uuid())
  name             String
  position         String
  number           Int?
  age              Int?
  photo            String?
  nationality      String?
  status           String    @default("available")
  nickname         String?
  preferredFoot    String?
  joinedAt         DateTime?
  injuryType       String?
  injuryZone       String?
  injuryReturnDate DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Formation {
  id       String  @id @default(uuid())
  matchId  String
  scheme   String
  isLineup Boolean @default(true)
  match    Match   @relation(fields: [matchId], references: [id])
}

model News {
  id          String     @id @default(uuid())
  title       String
  body        String
  category    String
  slug        String     @unique
  url         String?
  status      String     @default("draft")
  publishedAt DateTime?
  authorId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  imageUrl    String?
  urgent      Boolean    @default(false)
  comments    Comment[]
  author      User       @relation(fields: [authorId], references: [id])
  likes       NewsLike[]
}

model Comment {
  id         String        @id @default(uuid())
  newsId     String
  userId     String
  body       String
  createdAt  DateTime      @default(now())
  parentId   String?
  reportedAt DateTime?
  news       News          @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies    Comment[]     @relation("CommentReplies")
  likes      CommentLike[]
}

model CommentLike {
  id        String  @id @default(uuid())
  commentId String
  userId    String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  keys      Json
  userId    String?
  createdAt DateTime @default(now())
}

model NewsLike {
  id     String @id @default(uuid())
  newsId String
  userId String
  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([newsId, userId])
}

model Match {
  id               String            @id @default(uuid())
  homeTeam         String
  awayTeam         String
  homeScore        Int?
  awayScore        Int?
  status           String
  minute           Int?
  competition      String?
  date             DateTime
  type             String            @unique
  updatedAt        DateTime          @updatedAt
  manualOverride   Boolean           @default(false)
  stadium          String?
  penaltyWinner    String?
  aiPrediction     String?           @db.Text
  Formation        Formation[]
  LiveChatMessage  LiveChatMessage[]
  predictions Prediction[]
  events      MatchEvent[]
  statistics  Json?             // ESPN match stats snapshot
  referee     String?           // Árbitro designado
  tvChannel   String?           // Canal de TV que transmite
}

model LiveChatMessage {
  id String @id @default(uuid())
  matchId   String
  userId    String
  body      String
  createdAt DateTime @default(now())
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Prediction {
  id String @id @default(uuid())
  userId    String
  matchId   String
  choice    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model MatchEvent {
  id           String   @id @default(uuid())
  matchId      String
  type         String   // goal, own-goal, penalty-goal, penalty-miss, yellow-card, red-card, substitution, var, period-start, period-end
  minute       Int
  team         String
  playerName   String?
  playerInName String?  // player entering (substitutions only)
  assistName   String?  // assist provider (goals only)
  detail       String?  // free text (VAR reason, penalty detail, etc.)
  period       Int      @default(1)
  createdAt    DateTime @default(now())
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, minute])
}
