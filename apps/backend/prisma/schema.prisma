generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password_hash   String
  display_name    String
  avatar_url      String?
  role            String            @default("user")
  isBanned        Boolean           @default(false)
  created_at      DateTime          @default(now())
  points          Int               @default(0)
  city            String?
  country         String?
  fanSince        Int?
  googleId        String?           @unique
  notifGoals      Boolean           @default(true)
  notifMatch      Boolean           @default(true)
  notifNews       Boolean           @default(false)
  quietFrom       Int?
  quietTo         Int?
  comments        Comment[]
  liveChatMsgs    LiveChatMessage[]
  news            News[]
  likes           NewsLike[]
  predictions     Prediction[]
  commentLikes    CommentLike[]
  surveyVotes     SurveyVote[]
  favorites       Favorite[]
  activities      UserActivity[]
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Player {
  id               String         @id @default(uuid())
  name             String
  position         String
  number           Int?
  age              Int?
  photo            String?
  nationality      String?
  status           String         @default("available")
  nickname         String?
  preferredFoot    String?
  joinedAt         DateTime?
  injuryType       String?
  injuryZone       String?
  injuryReturnDate DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  photos           Json?
  manualGoals        Int?
  manualAssists      Int?
  manualAppearances  Int?
  manualMinutes      Int?
  manualYellowCards  Int?
  manualRedCards     Int?
  ratings          PlayerRating[]
}

model PlayerRating {
  id        String   @id @default(uuid())
  matchId   String
  playerId  String
  rating    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([matchId])
}

model Formation {
  id       String  @id @default(uuid())
  matchId  String  @unique
  scheme   String
  isLineup Boolean @default(true)
  type     String  @default("probable")
  lineup   Json?
  match    Match   @relation(fields: [matchId], references: [id])
}

model News {
  id          String     @id @default(uuid())
  title       String
  body        String
  category    String
  slug        String     @unique
  url         String?
  status      String     @default("draft")
  publishedAt DateTime?
  authorId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  imageUrl    String?
  urgent      Boolean    @default(false)
  tags        String[]
  comments    Comment[]
  author      User       @relation(fields: [authorId], references: [id])
  likes       NewsLike[]
}

model Comment {
  id         String        @id @default(uuid())
  newsId     String
  userId     String
  body       String
  createdAt  DateTime      @default(now())
  parentId   String?
  reportedAt DateTime?
  hidden     Boolean       @default(false)
  news       News          @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies    Comment[]     @relation("CommentReplies")
  likes      CommentLike[]
}

model CommentLike {
  id        String  @id @default(uuid())
  commentId String
  userId    String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  keys      Json
  userId    String?
  createdAt DateTime @default(now())
}

model NewsLike {
  id     String @id @default(uuid())
  newsId String
  userId String
  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([newsId, userId])
}

model Match {
  id               String            @id @default(uuid())
  homeTeam         String
  awayTeam         String
  homeScore        Int?
  awayScore        Int?
  status           String
  minute           Int?
  competition      String?
  season           String?
  date             DateTime
  type             String            @unique
  updatedAt        DateTime          @updatedAt
  manualOverride   Boolean           @default(false)
  stadium          String?
  penaltyWinner    String?
  aiPrediction     String?           @db.Text
  Formation        Formation[]
  LiveChatMessage  LiveChatMessage[]
  predictions Prediction[]
  events      MatchEvent[]
  statistics  Json?
  photos      Json?
  referee     String?
  tvChannel   String?
  ratings     PlayerRating[]
}

model LiveChatMessage {
  id String @id @default(uuid())
  matchId   String
  userId    String
  body      String
  createdAt DateTime @default(now())
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Prediction {
  id String @id @default(uuid())
  userId    String
  matchId   String
  choice    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model MatchEvent {
  id           String   @id @default(uuid())
  matchId      String
  type         String
  minute       Int
  team         String
  playerName   String?
  playerInName String?
  assistName   String?
  detail       String?
  period       Int      @default(1)
  createdAt    DateTime @default(now())
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, minute])
}

model Survey {
  id        String       @id @default(uuid())
  question  String
  options   Json         // [{id: string, label: string}]
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  closedAt  DateTime?
  votes     SurveyVote[]
}

model SurveyVote {
  id        String   @id @default(uuid())
  surveyId  String
  userId    String
  optionId  String
  createdAt DateTime @default(now())
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  type      String   // "player" | "news" | "match"
  targetId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, targetId])
  @@index([userId, type])
}
