generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------
// TABLA DE USUARIOS (Hinchas, Editores y Admin)
// --------------------------------------------------
model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password_hash String
  display_name  String
  avatar_url    String?
  role          String     @default("user")
  created_at    DateTime   @default(now())
  news          News[]
  comments      Comment[]
  likes         NewsLike[]
}

// --------------------------------------------------
// TABLA DEL PLANTEL / JUGADORES
// --------------------------------------------------
model Player {
  id          String   @id @default(uuid())
  name        String
  position    String // 'Goalkeeper', 'Defender', 'Midfielder', 'Attacker'
  number      Int? // Dorsal del jugador
  age         Int? // Edad
  photo       String? // URL de la foto oficial de la API
  nationality String? // Nacionalidad
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --------------------------------------------------
// TABLA DE FORMACIONES TÁCTICAS
// --------------------------------------------------
model Formation {
  id       String  @id @default(uuid())
  matchId  String
  match    Match   @relation(fields: [matchId], references: [id])
  scheme   String // ej: 4-3-3
  isLineup Boolean @default(true)
}

// --------------------------------------------------
// TABLA DE NOTICIAS
// --------------------------------------------------
model News {
  id          String     @id @default(uuid())
  title       String
  body        String
  category    String
  slug        String     @unique
  url         String?
  imageUrl    String?
  status      String     @default("draft")
  publishedAt DateTime?
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  comments    Comment[]
  likes       NewsLike[]
}

// --------------------------------------------------
// COMENTARIOS DE NOTICIAS
// --------------------------------------------------
model Comment {
  id        String   @id @default(uuid())
  newsId    String
  news      News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

// --------------------------------------------------
// LIKES DE NOTICIAS
// --------------------------------------------------
model NewsLike {
  id     String @id @default(uuid())
  newsId String
  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([newsId, userId])
}

// --------------------------------------------------
// TABLA DE PARTIDOS
// --------------------------------------------------

model Match {
  id             String      @id @default(uuid())
  type           String      @unique // Identificador para saber si es "LATEST" (Último) o "NEXT" (Próximo)
  homeTeam       String
  awayTeam       String
  homeScore      Int?
  awayScore      Int?
  status         String // "finished", "live", "scheduled"
  minute         Int?
  date           DateTime
  competition    String? // Ej: "Liga Profesional", "Copa Libertadores"
  stadium        String?
  manualOverride Boolean     @default(false) // Si true, el sync no lo sobreescribe
  penaltyWinner  String?     // Nombre del equipo ganador por penales (cuando scores iguales)
  updatedAt      DateTime    @updatedAt
  Formation      Formation[]
}
